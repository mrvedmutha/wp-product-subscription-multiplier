{
  "name": "eternal-labs/eternal-subscription",
  "description": "Eternal Labs WooCommerce supply plan plugin",
  "type": "wordpress-plugin",
  "require": {},
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.10",
    "wp-coding-standards/wpcs": "^3.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "phpstan/phpstan": "^1.12",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "php-stubs/woocommerce-stubs": "^9.0"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "optimize-autoloader": true
  },
  "scripts": {
    "phpcs": "phpcs --standard=phpcs.xml inc/ eternal-subscription.php",
    "phpstan": "phpstan analyse --configuration=phpstan.neon --no-progress"
  },
  "minimum-stability": "stable"
}
